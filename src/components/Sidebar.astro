---
import '../styles/global.css';
const { posts } = Astro.props;
---



<div>
  <aside class="sidebar">
    <section class="main-nav">
      <nav class="nav-body">
        <a class="nav-link" href="/">Home</a>
        <a class="nav-link" href="/blog">All Blogs</a>
      </nav>
    </section>
    
    <section class="blog-nav">
      <h2>Posts</h2>
      <nav class="nav-body">
        {posts.map((post) => (
          <a class="nav-link" href={`/blog/${post.id}`}>
            {post.data.title}
          </a>
        ))}
      </nav>
    </section>
  </aside>
</div>
